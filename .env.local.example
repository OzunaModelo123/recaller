# === Supabase ===
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — project ref (e.g. from Dashboard URL). Required for resumable uploads if you use a custom Supabase API domain instead of *.supabase.co.
# NEXT_PUBLIC_SUPABASE_PROJECT_REF=
# Optional — full TUS resumable endpoint URL (overrides project-ref / default host mapping).
# NEXT_PUBLIC_SUPABASE_STORAGE_TUS_URL=
# Server-only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Optional — keep CLI migrations in sync with the hosted DB (see supabase/HOW_TO_RUN_SQL_MIGRATIONS.md)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-....pooler.supabase.com:6543/postgres
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# === AI — required for plan generation (see README “Plan generation API”) ===
# Stage 1 analysis: src/lib/ai/contentAnalyzer.ts (Claude)
ANTHROPIC_API_KEY=
# Stage 2 generation + Stage 3 validation + embeddings: OpenAI
OPENAI_API_KEY=

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Dashboard → Products → Prices: recurring price IDs for checkout (per-seat quantity).
# Starter = monthly/seat; Growth = annual/seat (must match PLANS in src/lib/billing/stripe.ts).
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# === Slack ===
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=
# 64-char hex (32 bytes) for AES-256-GCM encryption of stored bot tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SLACK_BOT_TOKEN_ENCRYPTION_KEY=

# === Microsoft Teams / Azure ===
# Required for /api/teams/install and the bot. Add the same keys in Vercel → Settings → Environment Variables (Production), then redeploy.
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
# Entra → App registration → Authentication → Web: add redirect URIs (replace host):
#   https://YOUR_HOST/api/teams/oauth
#   https://YOUR_HOST/api/teams/employee/oauth
# API permissions → Microsoft Graph → Delegated → User.Read → Grant admin consent (for employee self-link)
# Optional: nudge Microsoft login toward your company domain (verified Entra domain, e.g. contoso.com)
# TEAMS_EMPLOYEE_LOGIN_DOMAIN_HINT=contoso.com
# Optional but recommended: dedicated HMAC secret for Teams OAuth state signing
TEAMS_STATE_SECRET=
# Optional dev-only: skip JWT verification on /api/teams/messages (do not use in production)
# TEAMS_SKIP_JWT_VERIFY=true

# === Resend ===
RESEND_API_KEY=

# === Sentry ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional — set with SENTRY_AUTH_TOKEN on Vercel for source maps / release uploads
# SENTRY_ORG=
# SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === Vimeo (optional; captions for pasted Vimeo URLs) ===
VIMEO_ACCESS_TOKEN=

# === Inngest ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === App ===
# Used in server actions (e.g. team invite redirectTo). Must match where you run the app.
# Supabase Auth → Redirect URLs: same origin + /auth/invite* (invites), /callback* (OAuth/code), e.g. http://localhost:3000/auth/invite*
NEXT_PUBLIC_APP_URL=http://localhost:3000
